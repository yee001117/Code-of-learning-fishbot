#include <Arduino.h>
#include <Esp32PcntEncoder.h>
#include <Esp32McpwmMotor.h>
#include <PidController0.h>

Esp32PcntEncoder encoders[2]; // 创建一个数组用于存储两个编码器
Esp32McpwmMotor motor; // 创建一个名为motor的对象

PidController pid_controller[2];
int64_t last_ticks[2] = {0, 0};
int32_t delta_ticks[2] = {0, 0};
int64_t last_update_time = 0;
float current_speed[2] = {0, 0};

//函数控制电机的速度/闭环控制
void motorSpeedControl()
{
    int16_t dt = millis() - last_update_time;
    delta_ticks[0] = encoders[0].getTicks() - last_ticks[0];
    delta_ticks[1] = encoders[1].getTicks() - last_ticks[1];
    current_speed[0] = (delta_ticks[0] * 141.710 )/ dt;
    current_speed[1] = (delta_ticks[1] * 103.237 )/ dt;

    //为了下次还可以正常计算速度
    last_ticks[0] = encoders[0].getTicks();
    last_ticks[1] = encoders[1].getTicks();
    last_update_time = millis();
    //调用PID,获取动态输出值
    motor.updateMotorSpeed(0,pid_controller[0].update(current_speed[0]));
    motor.updateMotorSpeed(1,pid_controller[1].update(current_speed[1]));

}
void setup()
{
    // 1.初始化串口
    Serial.begin(115200); // 初始化串口通信，设置通信速率为115200
    motor.attachMotor(0, 22, 23);  // 将电机0连接到引脚22和引脚23
    motor.attachMotor(1, 12, 13);  // 将电机1连接到引脚12和引脚13
    encoders[0].init(0, 32, 33); // 初始化第一个编码器，使用GPIO 32和33连接
    encoders[1].init(1, 26, 25); // 初始化第二个编码器，使用GPIO 26和25连接
  
    pid_controller[0].update_pid(0.625,0.125,0.0);
    pid_controller[1].update_pid(0.625,0.125,0.0);
    pid_controller[0].out_limit(-100,100);
    pid_controller[1].out_limit(-100,100);
    pid_controller[0].update_target(100);//使用毫米为单位
    pid_controller[1].update_target(100);//使用毫米为单位

}

void loop()
{
    //motor.updateMotorSpeed(0, 70); // 设置电机0的速度(占空比)为负70%
    //motor.updateMotorSpeed(1, 70); // 设置电机1的速度(占空比)为正70%
    delay(10); // 等待10毫秒
    //计算编码器当前和上一次读取的数值之差
    motorSpeedControl();
 
    // 读取并打印两个编码器的计数器数值
    Serial.printf("speed1=%f,speed2=%f\n",current_speed[0],current_speed[1]);
 
}
