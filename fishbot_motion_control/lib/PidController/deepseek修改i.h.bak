#ifndef __PID_CONTROLLER_H__
#define __PID_CONTROLLER_H__

class PidController
{
public:
    PidController() = default;
    PidController(float kp, float ki, float kd);

private:
    float target_ = 0.0f;
    float kp_ = 0.0f;
    float ki_ = 0.0f;
    float kd_ = 0.0f;
    float out_min_ = -100.0f;
    float out_max_ =  100.0f;
    float intergral_up_ = 2500.0f; // 积分上限

    float error_ = 0.0f;
    float error_sum_ = 0.0f;
    float derror_ = 0.0f;
    float prev_error_ = 0.0f;

public:
    float update(float current, float dt);
    void update_target(float target);
    void update_pid(float kp, float ki, float kd);
    void reset();
    void out_limit(float min, float max);
    void set_integral_limit(float limit);

    // 调试接口
    float getError()      const { return error_; }
    float getIntegral()   const { return error_sum_; }
    float getDerivative() const { return derror_; }
};

#endif